# DATA FUNCTION

pytrends = TrendReq(hl='en-US', tz=360)

def get_data(kw_list):
    pytrends.build_payload(kw_list, timeframe='today 12-m')
    region_data = pytrends.interest_by_region()
    time_df = pytrends.interest_over_time()
    if 'isPartial' in time_df.columns:
        time_df = time_df.drop(columns=['isPartial'])
    return region_data, time_df


# LOADING ANIMATION HELPER

def show_progress(step, total, label_text):
    progress_bar.layout.visibility = 'visible'
    progress_bar.value = int((step / total) * 100)
    progress_label.value = f"⏳ {label_text}"

def hide_progress():
    progress_bar.layout.visibility = 'hidden'
    progress_label.value = " Done!"


# MAIN ANALYSIS FUNCTION

def run_analysis():
    global last_region_data, last_time_df, last_timestamp

    kw_list = [kw.strip() for kw in keyword_input.value.split(",")]
    total_steps = 4 + len(kw_list) * 3

    show_progress(1, total_steps, "Connecting to Google Trends...")
    print(" Data source: Live Google Trends")
    print(" Fetching Data...")

    region_data, time_df = get_data(kw_list)

    show_progress(2, total_steps, "Saving data to disk...")

    timestamp = datetime.datetime.now().strftime("%Y-%m-%d_%H-%M-%S")
    last_timestamp = timestamp
    last_region_data = region_data
    last_time_df = time_df

    region_data.to_csv(f"region_data_{timestamp}.csv")
    time_df.to_csv(f"time_data_{timestamp}.csv")

    if os.path.exists("region_data_master.csv"):
        region_data.to_csv("region_data_master.csv", mode='a', header=False)
    else:
        region_data.to_csv("region_data_master.csv")

    if os.path.exists("time_data_master.csv"):
        time_df.to_csv("time_data_master.csv", mode='a', header=False)
    else:
        time_df.to_csv("time_data_master.csv")

    print(" Data saved with history!")

    show_progress(3, total_steps, "Rendering trend comparison chart...")
    print("\n Combined Trend Comparison")

    plt.figure(figsize=(12, 5))
    for kw in kw_list:
        plt.plot(time_df.index, time_df[kw], label=kw, linewidth=2)
    plt.legend()
    plt.xticks(rotation=45)
    plt.title("Trend Comparison (All Keywords)", fontsize=14, fontweight='bold')
    plt.tight_layout()
    plt.savefig(f"trend_{timestamp}.png", dpi=150)
    plt.show()

    print("\n Individual Keyword Analysis")

    for i, kw in enumerate(kw_list):
        step = 4 + i * 3
        show_progress(step, total_steps, f"Analyzing: {kw}...")
        print(f"\n ANALYSIS FOR: {kw}")

        plt.figure(figsize=(10, 4))
        plt.plot(time_df.index, time_df[kw], color='#e94560', linewidth=2)
        plt.fill_between(time_df.index, time_df[kw], alpha=0.15, color='#e94560')
        plt.title(f"{kw} Trend", fontsize=13, fontweight='bold')
        plt.xticks(rotation=45)
        plt.tight_layout()
        plt.show()

        region_top = region_data.sort_values(by=kw, ascending=False).head(10)

        plt.figure(figsize=(9, 5))
        #  FIXED LINE — hue assigned, legend hidden, no FutureWarning
        sns.barplot(x=region_top[kw], y=region_top.index, hue=region_top.index, palette="rocket", legend=False)
        plt.title(f"{kw} - Top Countries", fontsize=13, fontweight='bold')
        plt.tight_layout()
        plt.show()

        show_progress(step + 1, total_steps, f"Pie chart: {kw}...")

        plt.figure(figsize=(7, 7))
        plt.pie(region_top[kw], labels=region_top.index, autopct='%1.1f%%',
                colors=sns.color_palette("rocket", len(region_top)))
        plt.title(f"{kw} Distribution", fontsize=13, fontweight='bold')
        plt.tight_layout()
        plt.show()

        if 'Bangladesh' in region_data.index:
            bd = region_data.loc['Bangladesh'][kw]
        else:
            bd = 0

        global_avg = region_data[kw].mean()

        print(f"🇧🇩 Bangladesh: {bd}")
        print(f" Global Avg: {round(global_avg, 2)}")
        time.sleep(1)

    show_progress(total_steps - 1, total_steps, "Generating insights & predictions...")

    print("\n Key Insights")
    top_keyword = time_df.mean().idxmax()
    fastest = (time_df.iloc[-1] - time_df.iloc[0]).idxmax()
    print("Most Popular:", top_keyword)
    print("Fastest Growing:", fastest)

    print("\n Alert System")
    for kw in kw_list:
        if 'Bangladesh' in region_data.index:
            bd = region_data.loc['Bangladesh'][kw]
        else:
            bd = 0
        global_avg = region_data[kw].mean()
        print(f"\n {kw}")
        if bd > global_avg:
            print(" High demand in Bangladesh")
        elif bd < global_avg:
            print(" Lower demand in Bangladesh")
        else:
            print(" Equal demand")

    
    # SMART REPORT
    
    print("\n SMART ANALYSIS REPORT\n")

    report = f"""
===== SMART ANALYSIS REPORT =====
Generated: {timestamp}

Keywords Analyzed: {', '.join(kw_list)}

Top Keyword: {top_keyword}
Fastest Growing: {fastest}

Business Insight:
- {fastest} is gaining popularity rapidly 📈
- Consider investing in this area

Recommendation:
Focus on {fastest} for better future growth.

================================
"""
    print(report)

    with open(f"smart_report_{timestamp}.txt", "w", encoding="utf-8") as f:
        f.write(report)

    print("\n Prediction")

    plt.figure(figsize=(12, 5))
    for kw in kw_list:
        df = time_df[[kw]].reset_index()
        df['time'] = np.arange(len(df))
        X = df[['time']]
        y = df[kw]
        model = LinearRegression()
        model.fit(X, y)
        future = pd.DataFrame({'time': np.arange(len(df), len(df) + 30)})
        pred = model.predict(future)
        plt.plot(range(len(df), len(df) + 30), pred, label=f"{kw} (forecast)", linewidth=2, linestyle='--')
    plt.legend()
    plt.title("Combined 30-Day Prediction", fontsize=14, fontweight='bold')
    plt.tight_layout()
    plt.show()

    hide_progress()
    print("\n Analysis Completed!")


#  DOWNLOAD HELPERS

def make_download_link(data_bytes, filename, label, mime="text/csv"):
    b64 = base64.b64encode(data_bytes).decode()
    href = f'<a href="data:{mime};base64,{b64}" download="{filename}" style="display:inline-block;padding:8px 18px;background:#2ecc71;color:white;border-radius:8px;text-decoration:none;font-weight:bold;margin:4px;">{label}</a>'
    return href

def on_download_csv(b):
    with download_output:
        clear_output()
        if last_region_data is None or last_time_df is None:
            print(" Run analysis first before downloading.")
            return

        # Region CSV
        region_buf = io.StringIO()
        last_region_data.to_csv(region_buf)
        region_bytes = region_buf.getvalue().encode()

        # Time CSV
        time_buf = io.StringIO()
        last_time_df.to_csv(time_buf)
        time_bytes = time_buf.getvalue().encode()

        link1 = make_download_link(region_bytes, f"region_data_{last_timestamp}.csv", "⬇️ Region Data CSV")
        link2 = make_download_link(time_bytes, f"time_data_{last_timestamp}.csv", "⬇️ Time Series CSV")
        display(HTML(f"<div style='margin:10px 0'>{link1} {link2}</div>"))

def on_download_report(b):
    with download_output:
        clear_output()
        kw_list = [kw.strip() for kw in keyword_input.value.split(",")]

        if last_time_df is None:
            print(" Run analysis first before downloading.")
            return

        top_keyword = last_time_df.mean().idxmax()
        fastest = (last_time_df.iloc[-1] - last_time_df.iloc[0]).idxmax()

        report = f"""
===== SMART ANALYSIS REPORT =====
Generated: {last_timestamp}

Keywords Analyzed: {', '.join(kw_list)}

Top Keyword: {top_keyword}
Fastest Growing: {fastest}

Business Insight:
- {fastest} is gaining popularity rapidly
- Consider investing in this area

Recommendation:
Focus on {fastest} for better future growth.

================================
"""
        report_bytes = report.encode()
        link = make_download_link(report_bytes, f"smart_report_{last_timestamp}.txt", "📄 Download Report TXT", mime="text/plain")
        display(HTML(f"<div style='margin:10px 0'>{link}</div>"))


# BUTTONS

def on_run_click(b):
    with output:
        clear_output()
        run_analysis()

run_button.on_click(on_run_click)

def run_analysis_auto():
    global update_count
    for _ in range(100):
        with output:
            clear_output()
            update_count += 1
            print(f" Auto Update: {update_count}")
            run_analysis()
        time.sleep(10)

def on_auto_click(b):
    run_analysis_auto()

auto_button.on_click(on_auto_click)
download_csv_button.on_click(on_download_csv)
download_report_button.on_click(on_download_report)
